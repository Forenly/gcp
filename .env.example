# Copy to .env and fill in. Do not commit the real .env.

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=lawn_advisor

# Google Cloud
GCP_PROJECT=project-f3c4dc98-497f-4eee-b60
VERTEX_LOCATION=us-central1
AGENT_RESOURCE=projects/<num>/locations/us-central1/reasoningEngines/<id>

# Server
PORT=8000
